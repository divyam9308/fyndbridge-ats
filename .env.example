# Frontend (Vite)
# These are exposed to the browser. Must be prefixed with VITE_.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Backend (Express / Vercel Serverless)
# These are server-only secrets. Never prefix with VITE_.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key
FRONTEND_URL=https://your-vercel-app.vercel.app

# Gemini AI
GEMINI_API_KEY_PRIMARY=your-primary-gemini-key
GEMINI_API_KEY_SECONDARY=your-secondary-gemini-key
GEMINI_MODEL=gemini-2.0-flash-lite
